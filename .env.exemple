AZURE_OPENAI_API_KEY = SUA_CHAVE_AQUI # Substitua 'SUA_CHAVE_AQUI' pela sua chave de API do Azure OpenAI. Certifique-se de manter as aspas ao redor da chave.

AZURE_ENDPOINT = SEU_ENDPOINT_AQUI # Substitua 'SEU_ENDPOINT_AQUI' pelo seu endpoint do Azure OpenAI. Certifique-se de manter as aspas ao redor do endpoint. Exemplo: 'https://seu-endpoint.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview'

AZURE_DEPLOYMENT = SEU_AZURE_DEPLOYMENT_AQUI # Substitua 'SEU_AZURE_DEPLOYMENT_AQUI' pelo nome do seu deployment do Azure OpenAI. Certifique-se de manter as aspas ao redor do nome do deployment.

AZURE_API_VERSION=SUA_VERSAO_API_AQUI # Substitua 'SUA_VERSAO_API_AQUI' pela versão da API do Azure OpenAI que você deseja usar. Certifique-se de manter as aspas ao redor da versão da API.

OPENAI_MODEL = SEU_MODELO_OPENAI_AQUI # Substitua 'SEU_MODELO_OPENAI_AQUI' pelo nome do modelo do OpenAI que você deseja usar. Certifique-se de manter as aspas ao redor do nome do modelo.

CHATBOT_MAX_TOKENS = SEU_NUMERO_MAXIMO_DE_TOKENS_AQUI # Defina o número máximo de tokens que o chatbot pode usar em uma resposta. Ajuste conforme necessário.

CHATBOT_REASONING_EFFORT = SEU_NIVEL_DE_ESFORCO_DE_RACIOCINIO_AQUI # Defina o nível de esforço de raciocínio que o chatbot deve usar. Pode ser 'minimal', 'moderate' ou 'high'. Ajuste conforme necessário.

CHATBOT_TEMPERATURE = SEU_VALOR_DE_TEMPERATURA_AQUI # Defina a temperatura para controlar a criatividade das respostas do chatbot. Valores mais baixos (ex: 0.2) tornam as respostas mais conservadoras, enquanto valores mais altos (ex: 0.8) tornam as respostas mais criativas. Ajuste conforme necessário.
